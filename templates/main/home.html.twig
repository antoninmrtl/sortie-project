{% extends 'base.html.twig' %}

{% block title %}{{ parent() }} Home{% endblock %}

{% block extraStyle %}
    {{ parent() }}
{% endblock %}

{% block body %}
    <div class="p-5">

    <div class="flex justify-center">
        <div class="border-4 border-yellow-500 bg-black text-white w-5/6 h-auto p-5">
            <h1 class="text-[3rem]">Bienvenue à l'auberge des quêtes !</h1>
            <h2 class="text-[2rem]">Vivez l'aventure</h2>
        </div>
    </div>

        <article class="p-5">
            <div>

            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12 p-20">
                {% for quest in quests %}
                    <div class="border border-yellow-500 flex flex-col gap-y-4 p-4 bg-[#1A1A1A] text-white shadow-md">
                        <div class="flex justify-between">
                            <h1 class="font-bold text-xl">
                                {{ quest.name }}
                            </h1>

                            <h2>{{ quest.status.label }}</h2>

                        </div>


                        {# Le flex-grow permet à la description de prendre tout l'espace libre,
                       poussant ainsi les dates toujours tout en bas, même si le texte est court #}
                        <h3 class="flex-grow">
                            {{ quest.infoQuest }}
                        </h3>

                        <div class="flex justify-between">
                            <div>
                                <h3>
                                    Places : {{ quest.nbMaxInscription }} |
                                    Durée : {{ quest.duration }}h
                                </h3>
                            </div>
                            <div>
                                {{ quest.promoter.username }}
                            </div>
                        </div>

                        <hr class="border-yellow-500/30">

                        <div class="text-sm">
                            Début : {{ quest.startDateTime ? quest.startDateTime|date('Y-m-d H:i') : 'N/A' }}<br>
                            Fin Inscription
                            : {{ quest.inscriptionLimitDate ? quest.inscriptionLimitDate|date('Y-m-d H:i') : 'N/A' }}
                        </div>
                        <div class="mt-2 flex gap-4">
                            <a href="{{ path('quest_show', {'id': quest.id}) }}" class="text-yellow-600 hover:underline">Voir</a>
                            {% if app.user and quest.users.contains(app.user) %}
                                <a href="{{ path('quest_desister', {'id': quest.id}) }}">se desister</a>
                            {% else %}

                                {% if quest.status.label == 'En cours' or quest.status.label == 'Créee' or quest.status.label == 'Ouverte' %}
                                    <a href="{{ path('quest_inscription', {'id': quest.id}) }}"
                                       class="text-yellow-600 hover:underline">s'inscrire</a>
                                {% endif %}
                            {% endif %}



                            {% if quest.status.label not in ['Cloturée', 'Annulée', 'Passée'] %}
                                {% if is_granted('ROLE_ADMIN') %}
                                    <a href="{{ path('quest_edit', {'id': quest.id}) }}"
                                       class="text-yellow-600 hover:underline">Modifier</a>
                                {% endif %}
                            {% endif %}
                        </div>
                    </div>
                {% else %}
                    <p class="col-span-full text-center text-xl">Aucune quête trouvée sur le tableau.</p>
                {% endfor %}

            </div>

            <div class="mt-8">
                <a href="{{ path('quest_create') }}" class="btn text-white">Créer une nouvelle quête</a>
            </div>
        </article>
    </div>

{% endblock %}
