{% extends 'base.html.twig' %}

{% block title %}{{ parent() }} Home{% endblock %}
{% block extraStyle %}
    <style>
        body {
            background-image: url("{{ asset('images/Image.png') }}");
            background-size: cover;
            background-color: gray;
            background-blend-mode: luminosity;

        }
    </style>
{% endblock %}

{% block body %}
    <div class="p-5">

    <div class="flex justify-center">
        <div class="border-4 border-yellow-500 bg-black text-white w-1/2">
            <h1>Welcome</h1>
        </div>
    </div>

    {% for quest in quests %}
        <div>
            <h3 class="text-white">{{ quest.name }}</h3>
            <h3 class="text-white">{{ quest.status.label }}</h3>
        </div>

    {% endfor %}
    </div>

{% endblock %}
