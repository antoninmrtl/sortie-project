{% extends 'base.html.twig' %}

{% block title %}{{ parent() }} Home{% endblock %}
{% block extraStyle %}
    <style>
        body {

            background-image: linear-gradient(rgba(0, 0, 0, 0.5), rgba(0, 0, 0, 0.7)), url("{{ asset('images/Image.png') }}");
            background-color: #1A1A1A;
            background-size: contain;
            background-repeat: no-repeat;
            min-height: 100vh;
        }
    </style>
{% endblock %}

{% block body %}

    <h1 class="text-[4rem] mb-3 font-weight-normal text-amber-500 text-left">Profil</h1>

    {% if is_granted('IS_AUTHENTICATED_FULLY') %}

        <div class="border border-yellow-500 flex flex-col gap-y-4 p-4 bg-[#1A1A1A] text-white shadow-md tracking-tight">

<div>
            <img src="{{ asset('assets/images/profilePicture/' ~ app.user.profilePicture) }}"
                 class="border border-yellow-500"
                 style="width:120px;"
                 alt="{{ app.user.username }}">
</div>


            <div class="flex flex-col gap-y-2">
                <p>Email: {{ app.user.email }}</p>
                <p>Pseudo: {{ app.user.username }}</p>
                <p>Nom: {{ app.user.firstname }}</p>
                <p>Prénom: {{ app.user.lastname }}</p>
                <p>Teléphone: {{ app.user.phone }}</p>

                {% for quest in app.user.quest %}
                    <div>
                        quest : {{ quest.name }}
                    </div>


                {% endfor %}
            </div>


        </div>


        <div>


        </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12 p-20">
        <div class="border border-yellow-500 flex flex-col gap-y-4 p-4 bg-[#1A1A1A] text-white shadow-md">
            <h2 class="text-amber-500"> Quêtes inscrits </h2>
            <div class="mt-2 flex gap-4">

            </div>
        </div>


        <div class="border border-yellow-500 flex flex-col gap-y-4 p-4 bg-[#1A1A1A] text-white shadow-md">
            <h2 class="text-amber-500"> Quêtes Crées </h2>
        </div>

        <div class="text-white">
            <a href="{{ path('user_edit', {'id': app.user.id}) }}">edit</a>
            <form method="post" action="{{ path('user_delete', {'id': app.user.id}) }}"
                  onsubmit="return confirm('Are you sure you want to delete this item?');">
                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ app.user.id) }}">
                <button class="btn">Delete</button>
            </form>

        </div>
    </div>





    {% endif %}


{% endblock %}
