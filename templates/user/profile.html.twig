{% extends 'base.html.twig' %}

{% block title %}{{ parent() }} Home{% endblock %}
{% block extraStyle %}

        {{ parent() }}

{% endblock %}

{% block body %}
<article>
    <h1>Profil</h1>

    {% if is_granted('IS_AUTHENTICATED_FULLY') %}



        <div class="flex justify-center">
            <div class=" flex border border-yellow-500 bg-[#1A1A1A] text-white w-5/6 h-auto p-5 gap-4">

            <div>
                <img src="{{ asset('/images/profilePicture/' ~ app.user.profilePicture) }}"
                     class="border border-yellow-500 mt-5"
                     style="width:120px;"
                     alt="{{ app.user.username }}">
            </div>

            <div class="flex flex-col gap-y-2 mt-5">

                <p>Pseudo: {{ app.user.username }}</p>
                <p>Nom: {{ app.user.firstname }}</p>
                <p>Prénom: {{ app.user.lastname }}</p>
                <p>Email: {{ app.user.email }}</p>
                <p>Teléphone: {{ app.user.phone }}</p>
            </div>

                <div class="ml-auto flex flex-col items-end mt-30 gap-y-2 mr-6">

                    <div>
                        <form class="flex flex-col gap-y-4" method="post" action="{{ path('user_delete', {'id': app.user.id}) }}"
                              onsubmit="return confirm('Are you sure you want to delete this item?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ app.user.id) }}">
                            <button class="btn bg-[#1A1A1A]   px-4 py-2  border border-yellow-500 ">Delete</button>

                            <div>
                                <a href="{{ path('user_edit', {'id': app.user.id}) }}">Modifier mon profile</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>





</div>
        <div >
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-2 gap-12 p-20 ">
            <div class="border border-yellow-500 flex flex-col gap-y-4 p-4 bg-[#1A1A1A] text-white shadow-md">
                <h2 class="text-amber-500"> Quêtes inscrits </h2>
                {% for quest in app.user.quest %}
                    <div class="mt-2 flex gap-4">
                        <h2> quests : {{ quest.name }}</h2>
                    </div>

                <hr class="border-yellow-500/30">
                    <div>
                        <a href="{{ path('quest_show', {'id': quest.id}) }}" class="text-yellow-600 hover:underline flex flex-col items-end  gap-y-2 mr-6">Détail</a>
                    </div>
                {% else %}
                    <p class="col-span-full text-center text-xl">Aucune quête trouvée.</p>
                {% endfor %}
                </div>



            <div class="border border-yellow-500 flex flex-col gap-y-4 p-4 bg-[#1A1A1A] text-white shadow-md">
                <h2 class="text-amber-500"> Quêtes Crées </h2>
                {% for quest in app.user.quest %}
                    <div class="mt-2 flex gap-4">
                        <h2> quest : {{ quest.name }}</h2>
                    </div>
                    <hr class="border-yellow-500/30">
                    <div>
                        <a href="{{ path('quest_show', {'id': quest.id}) }}" class="text-yellow-600 hover:underline flex flex-col items-end  gap-y-2 mr-6">Voir Détail</a>
                    </div>
                {% else %}
                    <p class="col-span-full text-center text-xl">Aucune quête trouvée.</p>
                {% endfor %}
            </div>

            <div class="border border-yellow-500 flex flex-col gap-y-4 p-4 bg-[#1A1A1A] text-white shadow-md">
                <h2 class="text-amber-500"> Quêtes Enregistrées </h2>
                {% for quest in questCreate %}
                    <div class="mt-2 flex gap-4">
                        <h2> quest : {{ quest.name }}</h2>
                    </div>
                    <hr class="border-yellow-500/30">
                    <div>
                        <a href="{{ path('quest_show', {'id': quest.id}) }}" class="text-yellow-600 hover:underline flex flex-col items-end  gap-y-2 mr-6">Voir Détail</a>
                    </div>
                {% else %}
                    <p class="col-span-full text-center text-xl">Aucune quête trouvée.</p>
                {% endfor %}
            </div>


        </div>

        </div>


    {% endif %}

</article>
    {% endblock %}
