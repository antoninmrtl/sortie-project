{% extends 'base.html.twig' %}

{% block title %}Edit User{% endblock %}



{% block extraStyle %}
    <style>
        body {

            background-image: linear-gradient(rgba(0, 0, 0, 0.5), rgba(0, 0, 0, 0.7)), url("{{ asset('images/Image.png') }}");
            background-color: #1A1A1A;
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            min-height: 100vh;
        }
    </style>
{% endblock %}




{% block body %}
    <h1 class="text-[4rem] mb-3 font-weight-normal text-amber-500 text-left ml-35 mt-15" >Edit User</h1>

{% if is_granted('IS_AUTHENTICATED_FULLY') %}


<div class="flex justify-center">
    <div class=" flex border border-yellow-500 bg-[#1A1A1A] text-white w-5/6 h-auto p-5 gap-4">


    {{ include('user/_form.html.twig', {'button_label': 'Update'}) }}

    <a href="{{ path('user_index') }}">back to list</a>

    {{ include('user/_delete_form.html.twig') }}


    </div>
</div>
{% endif %}
{% endblock %}
