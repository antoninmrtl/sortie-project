{% extends 'base.html.twig' %}

{% block title %}User index{% endblock %}

{% block extraStyle %}
    <style>
        body {

            background-image: linear-gradient(rgba(0, 0, 0, 0.6), rgba(0, 0, 0, 0.7)), url("{{ asset('images/Image.png') }}");
            background-color: #1A1A1A;
            background-size: contain;
            background-repeat: no-repeat;
            min-height: 100vh;
        }
    </style>
{% endblock %}

{% block body %}
    <h1 class="text-[4rem] mb-3 font-weight-normal text-amber-500 text-left">User index</h1>
    <div class="flex justify-center p-5">


    <table class="table text-white border border-yellow-500 bg-black w-2/3  p-5" >
        <thead>
            <tr>
{#                <th>Id</th>#}
                <th>Firstname</th>
                <th>Lastname</th>
                <th>PhoneNumber</th>
                <th>Mail</th>
                <th>Actif</th>
                <th>ProfilePicture</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for user in users %}
            <tr>
                {% if is_granted('ROLE_ADMIN') %}
                <td>{{ user.id }}</td>
                {% endif %}
                <td>{{ user.firstname }}</td>
                <td>{{ user.lastname }}</td>
                <td>{{ user.phone }}</td>
                <td>{{ user.email }}</td>
                <td>{{ user.active ? 'Yes' : 'No' }}</td>
                <td>{{ user.profilePicture }}</td>
                <td>
                    <a href="{{ path('user_show', {'id': user.id}) }}">show</a>
                    {% if is_granted('ROLE_ADMIN') %}
                    <a href="{{ path('user_edit', {'id': user.id}) }}">edit</a>
                                {{ include('user/_delete_form.html.twig') }}
                    {% endif %}
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="11">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
    </div>





        <a href="{{ path('user_create') }}">Create new</a>


{% endblock %}
