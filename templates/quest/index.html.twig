{% extends 'base.html.twig' %}

{% block title %}Quêtes{% endblock %}

{% block extraStyle %}
    {{ parent() }}
{% endblock %}

{% block body %}

    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="p-4 mb-2 text-white font-bold bg-{{ label == 'success' ? 'green' : 'red' }}-500">
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}
    <article class="p-5">
        <h1 class="text-[5rem]  text-amber-500">Quêtes</h1>
        <div class="text-white mt-8 ml-4">
            {{ form_start(questForm, {'method': 'GET'}) }}


            <div class="mb-4">
                {{ form_widget(questForm.name, {'attr': {'class': 'bg-gray-100 rounded-lg px-4 py-2 w-max text-black'}}) }} {{ form_errors(questForm.name) }}
            </div>

            <div class="flex gap-4 items-center">
                {% if app.user %}
                    {{ form_row(questForm.isPromoter) }}
                    {{ form_row(questForm.isRegistered) }}

                {% else %}
                    {% do questForm.isPromoter.setRendered() %}
                    {% do questForm.isRegistered.setRendered() %}
                {% endif %}
                <div class="flex gap-4 items-end">
                    {{ form_row(questForm.startDate) }}
                    {{ form_row(questForm.endDate) }}
                </div>

                <button class="text-black bg-white p-1 hover:bg-yellow-500" type="submit">
                    Rechercher
                </button>
            </div>
            {{ form_end(questForm) }}
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12 p-20">
            {% for quest in quests %}
            {% if quest.status.label == 'Annulée' %}
            <div
                class=" grayscale border border-yellow-500 flex flex-col gap-y-4 p-4 bg-[#1A1A1A] text-white shadow-md">
                {% elseif quest.status.label == 'Ouverte' %}
                <div class="border border-green-500 flex flex-col gap-y-4 p-4 bg-[#1A1A1A] text-white shadow-md">
                    {% elseif quest.status.label == 'En cours' %}
                    <div class="border border-green-500 flex flex-col gap-y-4 p-4 bg-[#1A1A1A] text-white shadow-md">
                        {% else %}
                        <div
                            class="border border-yellow-500 flex flex-col gap-y-4 p-4 bg-[#1A1A1A] text-white shadow-md">

                            {% endif %}
                            <div class="flex justify-between">
                                <h1 class="font-bold text-[2rem] text-amber-500">
                                    {{ quest.name }}
                                </h1>

                                <h2>{{ quest.status.label }}</h2>

                            </div>

                            <h3 class="flex-grow">
                                {{ quest.infoQuest }}
                            </h3>

                            <div class="flex justify-between">
                                <div>
                                    <h3>
                                        Places : {{ quest.nbMaxInscription }} |
                                        Durée : {{ quest.duration }}h
                                    </h3>
                                </div>
                                <div>
                                    {{ quest.promoter.username }}
                                </div>
                            </div>

                            <hr class="border-yellow-500/30">

                            <div class="text-sm">
                                Début : {{ quest.startDateTime ? quest.startDateTime|date('Y-m-d H:i') : 'N/A' }}<br>
                                Fin Inscription
                                : {{ quest.inscriptionLimitDate ? quest.inscriptionLimitDate|date('Y-m-d H:i') : 'N/A' }}
                            </div>

                            <div class="mt-2 flex gap-4">
                                <a href="{{ path('quest_show', {'id': quest.id}) }}"
                                   class="text-yellow-600 hover:underline">Voir</a>
                                {% if is_granted('QUEST_UNREGISTER', quest) %}
                                    <a href="{{ path('quest_desister', {'id': quest.id}) }}">Se désister</a>
                                {% endif %}

                                {% if is_granted('QUEST_REGISTER', quest) %}
                                    <a href="{{ path('quest_inscription', {'id': quest.id}) }}" class="text-yellow-600 hover:underline">S'inscrire</a>
                                {% endif %}

                                {% if is_granted('QUEST_EDIT', quest) %}
                                <a href="{{ path('quest_edit', {'id': quest.id}) }}" class="text-yellow-600 hover:underline">Modifier</a>
                                {% endif %}
                            </div>
                        </div>
                        {% else %}
                            <p class="col-span-full text-center text-xl">Aucune quête trouvée sur le tableau.</p>
                        {% endfor %}

                    </div>


                    <div>
                        <a href="{{ path('quest_create') }}"
                           class="border border-yellow-500 btn text-yellow-500 p-1 font-(Pixelify Sans) text-center justify-center items-center">Créer
                            une nouvelle quête</a>
                    </div>


                </div>
            </div>

        </div>
    </article>
{% endblock %}
