{% extends 'base.html.twig' %}

{% block title %}Quest{% endblock %}

{% block body %}
    <h1>Quest</h1>



            <tr>
                <th>Id</th>
                <td>{{ quest.id }}</td>
            </tr>
            <tr>
                <th>Name</th>
                <td>{{ quest.name }}</td>
            </tr>
            <tr>
                <th>StartDateTime</th>
                <td>{{ quest.startDateTime ? quest.startDateTime|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>Duration</th>
                <td>{{ quest.duration }}</td>
            </tr>
            <tr>
                <th>InscriptionLimitDate</th>
                <td>{{ quest.inscriptionLimitDate ? quest.inscriptionLimitDate|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>NbMaxInscription</th>
                <td>{{ quest.nbMaxInscription }}</td>
            </tr>
            <tr>
                <th>InfoQuest</th>
                <td>{{ quest.infoQuest }}</td>
                <th>promoter</th>
                <td>{{ quest.promoter.username }}</td>
            </tr>

                <h1>image</h1>
                <img src="{{ asset('assets/images/pictureQuest/' ~ quest.picture) }}" alt="">


    <a href="{{ path('quest_index') }}">back to list</a>

    <a href="{{ path('quest_edit', {'id': quest.id}) }}">edit</a>

    {{ include('quest/_delete_form.html.twig') }}
{% endblock %}
