{{ form_start(form)}}
<div class="flex gap-4 p-4 scheme-light" >
    <div>
    <div class="  justify-items-start border border-yellow-500 flex flex-col gap-y-4 p-4 bg-[#1A1A1A] text-white shadow-md tracking-tight">
        {{ form_row(form.picture) }}
    </div>
    <h3 class="font-(family-name:--Pixelify)">Charger une image</h3>
</div>
    <div class="justify-items-start">
    <div>
        <div class="mb-4">    {{ form_label(form.name, null, {'label_attr': {'class': 'text-black mb-1'}}) }}
            {{ form_widget(form.name, {'attr': {'class': 'bg-gray-100 rounded-lg px-4 py-2 w-full'}}) }} {{ form_errors(form.name) }}</div>
        {#        {{ form_row(form.name)}}#}
    </div>
    <div>
        {{ form_row(form.startDateTime)}}
    </div>
    <div>
        {{ form_row(form.duration)}}
    </div>
    <div>
        {{ form_row(form.inscriptionLimitDate) }}
    </div>
    <div>
        {{ form_row(form.infoQuest) }}
    </div>
</div>
<div class="justify-items-start">
    <div>
        {{ form_row(form.campus) }}
    </div>
    <div class="flex">
        {{ form_row(form.place) }}
        <a            class="flex items-center justify-center border-2 border-yellow-600 rounded-full w-8 h-8 ml-8 text-yellow-600 hover:bg-yellow-600 hover:text-white transition-all font-bold text-[1rem]" href="{{ path('quest_index') }}">+</a>
    </div>
    <div>
        {{ form_row(form.nbMaxInscription) }}
    </div>
</div>
</div>
    {{ form_widget(form) }}
    <button class="btn">{{ button_label|default('Save') }}</button>
{{ form_end(form) }}
