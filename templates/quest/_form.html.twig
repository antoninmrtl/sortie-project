{{ form_start(form)}}
<div class="flex gap-4 p-4" >
    <div class="justify-items-start border border-yellow-500 flex flex-col gap-y-4 p-4 bg-[#1A1A1A] text-white shadow-md tracking-tight">
        {{ form_row(form.picture) }}
    </div>
    <div class="justify-items-start">
    <div>
        {{ form_row(form.name)  }}
    </div>
    <div>
        {{ form_row(form.startDateTime)}}
    </div>
    <div>
        {{ form_row(form.duration)}}
    </div>
    <div>
        {{ form_row(form.inscriptionLimitDate) }}
    </div>
    <div>
        {{ form_row(form.infoQuest) }}
    </div>
</div>
<div class="justify-items-start">
    <div>
        {{ form_row(form.campus) }}
    </div>
    <div class="flex">
        {{ form_row(form.place) }}
        <a            class="flex items-center justify-center border-2 border-yellow-600 rounded-full w-8 h-8 ml-8 text-yellow-600 hover:bg-yellow-600 hover:text-white transition-all font-bold text-[1rem]" href="{{ path('place_add') }}">+</a>
    </div>
    <div>
        {{ form_row(form.nbMaxInscription) }}
    </div>
</div>
</div>
    {{ form_widget(form) }}
<button type="submit" name="save_action" value="save" class="">
    Enregistrer le brouillon
</button>

<button type="submit" name="save_action" value="publish" class="">
    Publier la quête
</button>
{{ form_end(form) }}
