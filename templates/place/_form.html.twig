{{ form_start(form)}}
<div class="flex gap-4 p-4" >
    <div class="justify-items-start">
    <div>
        {{ form_row(form.name)  }}
    </div>
    <div>
        {{ form_row(form.street)}}
    </div>
    <div>
        {{ form_row(form.latitude)}}
